ainers/rust:1-bullseye",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "SOROBAN_NETWORK": "testnet"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "vadimcn.vscode-lldb"
